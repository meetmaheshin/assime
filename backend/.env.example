# Copy to .env and fill in. Never commit .env.

# ─── App ───────────────────────────────────────
ENV=dev
# 32+ char random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database (matches docker-compose host ports) ──
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5435/jarvis

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6381/0

# ─── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# Two-tier model strategy (swap versions freely — verify IDs at build time):
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_EMBED=text-embedding-3-small
# Embedding dimension MUST match the model above (3-small = 1536, 3-large = 3072).
# Changing this requires a DB migration of the memories.embedding column.
EMBED_DIM=1536

# Per-user daily token budget (cost guardrail; 0 = unlimited)
DAILY_TOKEN_BUDGET=200000

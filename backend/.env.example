# Copy to .env and fill in. Never commit .env.

# ─── App ───────────────────────────────────────
ENV=dev
# 32+ char random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database (matches docker-compose host ports) ──
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5435/jarvis

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6381/0

# ─── LLM provider ──────────────────────────────
# auto | openai | azure | stub
LLM_PROVIDER=auto

# ─── Standard OpenAI (if LLM_PROVIDER=openai) ──
OPENAI_API_KEY=
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_EMBED=text-embedding-3-small

# ─── Azure OpenAI / AI Foundry (if LLM_PROVIDER=azure) ──
# In Azure you call *deployment* names, not model names.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_DEPLOYMENT_REASONING=gpt-4.1-nano
AZURE_DEPLOYMENT_CHEAP=gpt-4.1-nano
# A separate embedding deployment is required to use Azure for embeddings.
AZURE_DEPLOYMENT_EMBED=

# ─── Embeddings (independent of chat) ──────────
# auto | local | openai | azure | stub
EMBEDDING_PROVIDER=local
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2

# Embedding dimension MUST match the embedding model:
#   all-MiniLM-L6-v2 = 384 | text-embedding-3-small = 1536 | 3-large = 3072
# Changing it requires migrating the memories.embedding column.
EMBED_DIM=384

# Per-user daily token budget (cost guardrail; 0 = unlimited)
DAILY_TOKEN_BUDGET=200000
